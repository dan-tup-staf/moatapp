# Postgres
POSTGRES_USER=moatapp
POSTGRES_PASSWORD=moatapp
POSTGRES_DB=moatapp

# JWT
JWT_SECRET=change-me-in-prod

# SMTP — sending mailbox. Defaults target Mailhog (dev). For real delivery set
# your provider's creds, e.g. Gmail/Workspace: smtp.gmail.com / 587 / starttls
# with an App Password (not your normal password).
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=false   # true for port 587 (Gmail/Workspace)
SMTP_USE_TLS=false    # true for port 465 (implicit TLS)
SMTP_FROM_EMAIL=      # address mail is sent from (usually = username)
SMTP_FROM_NAME=
SMTP_DAILY_LIMIT=50   # daily outbound cap (0 = unlimited)

# Scheduler — in-process tick that sends due campaign emails. On free hosting
# the service sleeps when idle; set CRON_SECRET and hit POST /api/v1/tick from
# an external cron for reliable cadence.
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60
SCHEDULER_RUN_SIGNALS=false   # auto-run signal scrapers (uses AI quota)
SIGNAL_INTERVAL_SECONDS=900
CRON_SECRET=

# Third-party API keys (optional — for future enrichment)
APOLLO_API_KEY=
HUNTER_API_KEY=

# AI provider for ICP + web_search signal channels (first set wins; Gemini
# preferred). Leave both empty to disable AI features (rest of app works).

# Google Gemini — FREE tier with Google Search grounding. Get a key at
# https://aistudio.google.com  (recommended, cheap default)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic — paid alternative (server-side web_search). Leave empty if using Gemini.
ANTHROPIC_API_KEY=
# Optional: override Anthropic endpoint (Anthropic-compatible gateway)
ANTHROPIC_BASE_URL=

# CORS — set true for hosted demos where the frontend is on another origin
# (Bearer-token auth, so wildcard CORS is safe). Keep false in real prod.
CORS_ALLOW_ALL=false
